<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Nội dung -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Tiêu đề + ô tìm kiếm -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lớp học của tôi"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_search_field"
                android:backgroundTint="@color/background"
                android:hint="Tìm lớp học..."
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:paddingHorizontal="14dp"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawableTint="@color/text_secondary"
                android:drawablePadding="8dp"
                android:inputType="text" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="48dp"
            android:text="Bạn chưa tham gia lớp học nào\nNhấn '+' để tham gia lớp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_classes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="88dp"
            android:clipToPadding="false" />
    </LinearLayout>

    <!-- Nút tham gia lớp nổi đè lên danh sách -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_join"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Tham gia lớp"
        app:backgroundTint="@color/primary_blue"
        app:tint="@color/white" />
</FrameLayout>
